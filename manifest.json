{
  "manifest_version": 2,
  "name": "InfoSci MS plan of study checker",
  "version": "1.5",
  "description": "Automatically checks UA InfoSci MSDS/MSIS plan of study requirements",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png" },
    "default_title": "InfoSci POS Checker"
  },
  "content_scripts": [
    {
      "matches": ["*://*.arizona.edu/*", "*://*.uaccess.arizona.edu/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": { "48": "icon.png" }
}
